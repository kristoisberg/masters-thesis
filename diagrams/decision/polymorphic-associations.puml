@startuml Polymorphic Associations
skinparam shadowing false
skinparam ConditionEndStyle hline
skinparam defaultTextAlignment center
start

repeat :**Read source class from project**;
    if (**Class is generated by the jOOQ code generator**\n----\nClass is preceded by comment "This class is generated by jOOQ.") then (yes)
        if (**Class represents a database table**\n----\nClass implements org.jooq.Table) then (yes)
            if (**Table has a type/kind column and an ID column with matcing prefixes/suffixes**\n----\nentity_kind + entity_id\nentity_response_kind + entity_response_id\nrow_kind + row_id\nselector_entity_kind + selector_entity_id) then (yes)
                if (**ID column is declared as a foreign key**\n----\nDetermined using the Keys.java file, looking for a ForeignKey\nfield with this table as the first argument of createForeignKey,\nand the ID column as the third argument) then (no)
                    :**Detect antipattern** (line span: both column definitions);
                endif
            endif
        endif
    endif
repeat while (**Project contains another source class?**) is (yes) not (no)

stop
@enduml
