@startuml naive-trees
skinparam shadowing false
skinparam ConditionEndStyle hline
skinparam defaultTextAlignment center
start

repeat :**Read source class from project**;
    if (**Class is generated by the jOOQ code generator**\n----\nClass is preceded by comment "This class is generated by jOOQ.") then (yes)
        if (**Class represents a database table**\n----\nClass implements org.jooq.Table) then (yes)
            if (**Column is the primary key**\n----\nDetermined using the Keys.java file, looking for the UniqueKey\nfield referenced in the getPrimaryKey method of the table class.\nYes, if the current column is referenced in that constraint) then (no)
                if (**Column has the same type as the primary key column**\n----\nDetermined by the second arguments of both createField calls) then (yes)
                    if (**Column name implies a tree structure (parent/child relationship)**\n----\nDetermined by the first argument of createField\n----\nparent_id, parent_version_id) then (yes)
                        :**Detect antipattern** (line span:\ndeclarations of the columns part of the foreign key);
                    endif
                endif
            endif
        endif
    endif
repeat while (**Project contains another source class?**) is (yes) not (no)

stop
@enduml
