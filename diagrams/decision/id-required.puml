@startuml id-required
skinparam shadowing false
skinparam ConditionEndStyle hline
skinparam defaultTextAlignment center
start

repeat :**Read source class from project**;
    if (**Class is generated by the jOOQ code generator**\n----\nClass is preceded by comment "This class is generated by jOOQ.") then (yes)
        if (**Class represents a database table**\n----\nClass implements org.jooq.Table) then (yes)
            repeat :**Read next column definition in class**\n----\nNext class field of type TableField;
                if (**Column is the primary key**\n----\nDetermined using the Keys.java file, looking for the UniqueKey\nfield referenced in the getPrimaryKey method of the table class.\nYes, if the current column is referenced in that constraint\n(third and succeeding arguments of createUniqueKey)) then (yes)
                    if (**Column is named "ID" (case-insensitive)**\n----\nDetermined using the first argument of createField) then (yes)
                        :**Detect antipattern** (line span:\nprimary key definition without comments);
                    else (no)
                        repeat :**Read next unique key belonging to the table**\n----\nRead from the Keys.java file, looking for UniqueKey fields,\nwhere the first argument of createUniqueKey references this table.\nThe previously found primary key field is excluded.;
                            if (**The other unique key only contains non-volatile values**\n----\nDetermined using the column's name (first argument of\ncreateField) and business logic\n----\ne.g., combination of unique + foreign key,\nexternal identifier, constant code) then (yes)
                            if (**The other unique key has one component**\n----\nDetermined by the number of arguments in\ncreateUniqueKey.Yes if three, no if more.) then (yes)
                                :**Detect antipattern** (line span:\nprimary key definition without comments);
                            (no) elseif (**The current primary key is referenced as a foreign key**\n----\nDetermined using the Keys.java file, looking for ForeignKey\nfields referencing the current primary key in the first\nargument of createForeignKey) then (no)
                                :**Detect antipattern** (line span:\nprimary key definition without comments);
                            endif
                        endif
                        repeat while (**Table has another unique key?**) is (yes) not (no)
                    endif
                endif
            repeat while (**Class has another column definition?**) is (yes) not (no)
        endif
    endif
repeat while (**Project contains another source class?**) is (yes) not (no)

stop
@enduml
