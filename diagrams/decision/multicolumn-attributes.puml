@startuml Multicolumn Attributes
skinparam shadowing false
skinparam ConditionEndStyle hline
skinparam defaultTextAlignment center
start

repeat :**Read source class from project**;
    if (**Class is generated by the jOOQ code generator**\n----\nClass is preceded by comment "This class is generated by jOOQ.") then (yes)
        if (**Class represents a database table**\n----\nClass implements org.jooq.Table) then (yes)
            :**Group all column names in the class**;
            repeat :**Analyse group of column names**;
                if (**Multiple column names follow a numbered pattern**\n----\nDetermined by the first arguments of all createField calls\n----\ntype_filter, type_filter1, type_filter2, type_filter3\nlevel_1, level_2, level_3) then (yes)
                    if (**All of these columns have the same data type**\n----\nDetermined by the second arguments of all createField calls) then (yes)
                        if (**Business logic of these columns is equivalent**\n----\nDetermined by inspecting business logic) then (yes)
                            :**Detect antipattern** (line span: all column definitions);
                        endif
                    endif
                endif
            repeat while (**More column groups to analyse?**) is (yes) not (no)
        endif
    endif
repeat while (**Project contains another source class?**) is (yes) not (no)

stop
@enduml
