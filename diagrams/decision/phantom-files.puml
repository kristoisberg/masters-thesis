@startuml phantom-files
skinparam shadowing false
skinparam ConditionEndStyle hline
skinparam defaultTextAlignment center
start

repeat :**Read source class from project**;
    if (**Class is generated by the jOOQ code generator**\n----\nClass is preceded by comment "This class is generated by jOOQ.") then (yes)
        if (**Class represents a database table**\n----\nClass implements org.jooq.Table) then (yes)
            repeat :**Read next column definition in class**\n----\nNext class field of type TableField;
                if (**Column is of textual type**\n----\nTEXT, VARCHAR, VARCHAR2, CLOB\nDetermined by the second argument of createField) then (yes)
                    if (**Column's qualified name implies a file reference**\n----\nDetermined by the class name and first argument of createField\n----\nartifacts.storage_key, data_files.name, file.path, log_photo.storage,\nmedia.media_path, onboarding_documents.filename, remote_files.path,\nresource.filename, stored_files.storage_key) then (yes)
                        if (**The file's life cycle is managed by this application,**\n**using this column as file reference**\n----\nDetermined by inspecting business logic to see if files are created\nand deleted in the same business flows as this table's rows) then (yes)
                            :**Detect antipattern** (line span: column definition);
                        endif
                    endif
                endif
            repeat while (**Class has another column definition?**) is (yes) not (no)
        endif
    endif
repeat while (**Project contains another source class?**) is (yes) not (no)

stop
@enduml
