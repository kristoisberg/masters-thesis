@startuml sql-injection
skinparam shadowing false
skinparam ConditionEndStyle hline
skinparam defaultTextAlignment center
start

repeat :**Read source class from project**;
    if (**Class is generated by the jOOQ code generator**\n----\nClass is preceded by comment "This class is generated by jOOQ.") then (no)
        if (**Class contains references to jOOQ DSL**\n----\norg.jooq.impl.DSL, org.jooq.DSLContext) then (yes)
            repeat :**Read next statement constructed using jOOQ DSL**\n----\nChain of methods starting with DSL/DSLContext;
                repeat :**Read next method call in statement**;
                    if (**Method is a plain SQL method**\n----\nDSL.field(String), DSL.condition(String)) then (yes)
                        if (**Input is a string variable**\n----\nNot a constant or literal,\nand of type String) then (yes)
                            if (**Input variable is validated or sanitised**\n----\nDetermined by inspecting the call tree,\nlooking for validation or sanitisation logic) then (yes)
                                :**Detect antipattern** (line span: Plain SQL method call);
                            endif
                        endif
                    endif
                repeat while (**Statement has another method call?**) is (yes) not (no)
            repeat while (**Class has another statement constructed using jOOQ DSL?**) is (yes) not (no)
        endif
    endif
repeat while (**Project contains another source class?**) is (yes) not (no)

stop
@enduml
