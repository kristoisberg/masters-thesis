@startuml Implicit Columns
skinparam shadowing false
skinparam ConditionEndStyle hline
skinparam defaultTextAlignment center
start

repeat :**Read source class from project**;
if (**Class is generated by the jOOQ code generator**\n----\nClass is preceded by comment "This class is generated by jOOQ.") then (no)
    if (**Class contains references to jOOQ DSL**\n----\nImport statements or explicit references to\norg.jooq.impl.DSL, org.jooq.DSLContext) then (yes)
        repeat :**Read next statement constructed using jOOQ DSL**\n----\nChain of methods starting with DSL/DSLContext;
            if (**Statement is a SELECT statement**\n----\nStarts with any variation of select or selectFrom) then (yes)
                if (**List of selected columns is fetched**\n----\nStatement is not embedded in fetchExists, fetchCount) then (yes)
                    if (**Statement implicitly fetches all columns**\n----\nselect(), selectDistinct(), select(TABLE),\nselectDistinct(TABLE), selectFrom(TABLE)) then (yes)
                        :**Detect antipattern** (line span:\nline(s) of explicit fetch);
                    (no) elseif (**Statement explicitly fetches all columns**\n----\nDSL.asterisk(), TABLE.fields(), TABLE.fieldStream()) then (yes)
                        :**Detect antipattern** (line span:\nline(s) of implicit fetch);
                    endif
                endif
            (no) elseif (**Statement is an INSERT/UPDATE/DELETE statement**\n----\nStarts with insertInto, update, deleteFrom) then (yes)
                if (**Statement fetches all columns of modified rows**\n----\nreturning(), returningResult(), returning(DSL.asterisk()),\nreturningResult(DSL.asterisk()), returning(TABLE.fields()),\nreturningResult(TABLE.fields()), returning(TABLE.fieldStream()),\nreturningResult(TABLE.fieldStream())))
                    :**Detect antipattern** (line span:\nline of fetch);
                endif
            endif
        repeat while (**Class has another statement constructed using jOOQ DSL?**) is (yes) not (no)
    endif

    if (**Class contains references to jOOQ generated DAOs**\n----\nImport statements or explicit references to classes\nin a package ending with .tables.daos) then (yes)
        repeat :**Read next call to a jOOQ generated repository method**\n----\nCall to a method from a class in a package ending\nwith .tables.daos;
            if (**Call is to a method fetching records**\n----\nfetch, fetchBy..., fetchOne, fetchOneById, findAll,\nfindById, findOptionalBy...) then (yes)
                :**Detect antipattern** (line span: line of fetching method);
            endif
        repeat while (**Class has another call to a jOOQ generated DAO method?**) is (yes) not (no)
    endif
endif
repeat while (**Project contains another source class?**) is (yes) not (no)

stop
@enduml
