@startuml standard-operating-procedures
skinparam shadowing false
skinparam ConditionEndStyle hline
skinparam defaultTextAlignment center
start

repeat :**Read source class from project**;
    if (**Class is generated by the jOOQ code generator**\n----\nClass is preceded by comment "This class is generated by jOOQ.") then (yes)
        if (**Class represents database triggers**\n----\nClass name is Triggers.java) then (yes)
            repeat :**Read next trigger definition**\n----\nNext class field with type Trigger;
                :**Detect antipattern** (line span: trigger definition);
            repeat while (**Class contains another trigger?**) is (yes) not (no)
        endif
    else (no)
        repeat :**Read next call to a stored function**\n----\nMethod from generated Routines.java class;
            :**Detect antipattern** (line span: method call);
        repeat while (**Class has another call to a stored function?**) is (yes) not (no)

        repeat :**Read next call to a Table Valued Function**\n----\nTABLE.call();
            :**Detect antipattern** (line span: Table Valued Function call);
        repeat while (**Class has another call to a Table Valued Function?**) is (yes) not (no)
    endif
repeat while (**Project contains another source class?**) is (yes) not (no)

stop
@enduml
