@startuml Metadata Tribbles
skinparam shadowing false
skinparam ConditionEndStyle hline
skinparam defaultTextAlignment center
start

repeat :**Read source class from project**;
    if (**Class is generated by the jOOQ code generator**\n----\nClass is preceded by comment "This class is generated by jOOQ.") then (yes)
        if (**Class represents a database table**\n----\nClass implements org.jooq.Table) then (yes)
            :**Group all column names in the table**;
            if (**Multiple columns share a common base name but are**\n**prefixed or suffixed with metadata categories**\n----\nDetermined by the first arguments of all createField calls\n----\ntron_amount, bitcoin_amount, ethereum_amount, matic_amount\ntron_balance, bitcoin_balance, ethereum_balance, matic_balance) then (yes)
                if (**All of these columns have the same data type**\n----\nDetermined by the second arguments of all createField calls) then (yes)
                    :**Detect antipattern** (line span: column definitions);
                endif
            endif

        (no) elseif (**Class represents a database schema**\n----\nClass extends org.jooq.impl.SchemaImpl) then (yes)
            :**Group all tables defined in the schema**;
            if (**Multiple tables share the same structure/columns but**\n**differ only by a metadata-based naming convention**\n----\nDetermined by the names of table-typed fields in the schema\n----\npayment_p2007_01, ..., payment_p2007_06) then (yes)
                    :**Detect antipattern** (line span: references to tables);
            endif
        endif
    endif
repeat while (**Project contains another source class?**) is (yes) not (no)

stop
@enduml
