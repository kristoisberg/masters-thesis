@startuml Keyless Entry
skinparam shadowing false
skinparam ConditionEndStyle hline
skinparam defaultTextAlignment center
start

repeat :**Read source class from project**;
    if (**Class is generated by the jOOQ code generator**\n----\nClass is preceded by comment "This class is generated by jOOQ.") then (yes)
        if (**Class represents a database table**\n----\nClass implements org.jooq.Table) then (yes)
            repeat :**Read next column definition in class**\n----\nNext class field of type TableField\n----\n**Note:** We did not find any multi-column\nvariants of this antipattern during annotation;
                if (**Column's name implies a reference to another or the same table**\n----\nDetermined by the first argument of createField\n----\ne.g., created_by, idalimento, org_id, parent_id, uid, updated_by) then (yes)
                    if (**This column is declared as a foreign key**\n----\nDetermined using the Keys.java file, looking for a\nForeignKey field with this table as the first argument of\ncreateForeignKey, and this column as the third argument) then (no)
                        if (**A suitable primary/unique key exists for this column to reference**\n(matching type and semantically matching name)\n----\nDetermined using the Keys.java file, looking for a name-wise semantically\nmatching UniqueKey field. Type-level matches are verified using field\ndefinitions in classes (second argument in createField).\n----\ncreated_by -> user.id\ndata_type.parent_id -> data_type.id\nidalimento -> alimento.idalimento\norg_id -> org.id\nuid -> user.uid\nupdated_by -> user.id) then (yes)
                            :**Detect antipattern** (line span: column definitions);
                        endif
                    endif
                endif
            repeat while (**Class has another column definition?**) is (yes) not (no)
        endif
    endif
repeat while (**Project contains another source class?**) is (yes) not (no)

stop
@enduml
