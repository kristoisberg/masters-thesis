@startuml Poor Man's Search Engine
skinparam shadowing false
skinparam ConditionEndStyle hline
skinparam defaultTextAlignment center
start

repeat :**Read source class from project**;
    if (**Class is generated by the jOOQ code generator**\n----\nClass is preceded by comment "This class is generated by jOOQ.") then (no)
        if (**Class contains references to jOOQ DSL**\n----\norg.jooq.impl.DSL, org.jooq.DSLContext) then (yes)
            repeat :**Read next statement constructed using jOOQ DSL**\n----\nChain of methods starting with DSL/DSLContext;
                if (**Statement is a SELECT statement**\n----\nStarts with any variation of select or selectFrom) then (yes)
                    if (**SELECT statement has a WHERE clause**\n----\nwhere) then (yes)
                        repeat :**Read next condition in the WHERE clause**;
                            if (**Condition translates to LIKE or ILIKE**\n**without implicit wildcards**\n----\nlike, ilike, likeIgnoreCase, notLike,\nnotIlike, notLikeIgnoreCase) then (yes)
                                if (**Final input value is constructed by the application**) then (yes)
                                    if (**Final input value starts and ends with % wildcards**) then (yes)
                                        :**Detect antipattern** (line span:\naffected condition in the WHERE clause);
                                    endif
                                else (no)
                                    :**Detect antipattern** (line span:\naffected condition in the WHERE clause);
                                endif
                            (no) elseif (**Condition translates to LIKE or ILIKE**\n**with implicit wildcards**\n----\ncontains, containsIgnoreCase, notContains,\nnotContainsIgnoreCase) then (yes)
                                :**Detect antipattern** (line span:\naffected condition in the WHERE clause);
                            endif
                        repeat while (**WHERE clause has another condition?**) is (yes) not (no)
                    endif
                endif
            repeat while (**Class has another statement constructed using jOOQ DSL?**) is (yes) not (no)
        endif
    endif
repeat while (**Project contains another source class?**) is (yes) not (no)

stop
@enduml
