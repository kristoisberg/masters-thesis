@startuml fear-of-the-unknown
skinparam shadowing false
skinparam ConditionEndStyle hline
skinparam defaultTextAlignment center
start

repeat :**Read source class from project**;
    if (**Class is generated by the jOOQ code generator**\n----\nClass is preceded by comment "This class is generated by jOOQ.") then (yes)
        if (**Class represents a database table**\n----\nClass implements org.jooq.Table) then (yes)
            repeat :**Read next column definition in class**\n----\nNext class field of type TableField;
                if (**Column is marked as nullable**\n----\nSecond argument in createField\ndoes not contain "nullable(false)"") then (yes)
                    if (**Column has a non-null default value**\n----\nSecond argument in createField contains\n"defaultValue" with a value that is not NULL) then (yes)
                        :**Detect antipattern** (line span: column definition);
                    endif

                    if (**Business logic treats the column as non-nullable**\n----\nDetermining by inspecting the business logic,\nverifying if the value can be NULL in practice) then (yes)
                        :**Detect antipattern** (line span: column definition);
                    endif
                endif
                
                if (**Column has a non-null default value?**\n----\nSecond argument in createField contains\n"defaultValue" with a value that is not NULL) then (yes)
                    if (**Default value represents a placeholder**\n**without a business meaning**\n----\n"defaultValue" is 0, -1, a very large or small value,\nUNIX epoch time, empty string) then (yes)
                        :**Detect antipattern** (line span: column definition);
                    endif
                endif
            repeat while (**Class has another column definition?**) is (yes) not (no)
        endif
    else (no)
        repeat :**Read next statement constructed using jOOQ DSL**\n----\nChain of methods starting with DSL/DSLContext;
            if (**Statement has a WHERE clause**\n----\nwhere) then (yes)
                repeat :**Read next condition in the WHERE clause**;
                    if (**Condition contains the NOT IN operator**\n----\nnotIn) then (yes)
                        :**Detect antipattern**\n(line span: NOT IN operator);
                    endif
                    if (**Condition contains self-equation**\n----\nCOLUMN.eq(COLUMN)) then (yes)
                        :**Detect antipattern**\n(line span: self-equation);
                    endif
                repeat while (**WHERE clause has another condition?**) is (yes) not (no)
            endif
        repeat while (**Class has another statement constructed using jOOQ DSL?**) is (yes) not (no)
    endif
repeat while (**Project contains another source class?**) is (yes) not (no)

stop
@enduml
