@startuml entity-attribute-value
skinparam shadowing false
skinparam ConditionEndStyle hline
skinparam defaultTextAlignment center
start

repeat :**Read source class from project**;
    if (**Class is generated by the jOOQ code generator**\n----\nClass is preceded by comment "This class is generated by jOOQ.") then (yes)
        if (**Class represents a database table**\n----\nClass implements org.jooq.Table) then (yes)
            :**Count columns in table**;
            if (**Table contains exactly three columns**\n----\n**Note:** We did not find any occurrences with\nadditional metadata columns in EAV tables.) then (yes)
                if (**Table contains a column with a name implying a reference to another table**\n----\nDetermined by the first argument of createField\n----\nname, uid, user_name) then (yes)
                    if (**Table contains a column with a name implying a generic attribute name/identifier column**\n----\nDetermined by the first argument of createField\n----\ndescription, key) then (yes)
                        if (**Table contains a column with a name implying a generic value column**\n----\nDetermined by the first argument of createField\n----\nvalue) then (yes)
                            :**Detect antipattern** (line span: column definition);
                        endif
                    endif
                endif
            endif
        endif
    endif
repeat while (**Project contains another source class?**) is (yes) not (no)

stop
@enduml