@startuml ambiguous-groups
skinparam shadowing false
skinparam ConditionEndStyle hline
skinparam defaultTextAlignment center
start

repeat :**Read source class from project**;
    if (**Class is generated by the jOOQ code generator**\n----\nClass is preceded by comment "This class is generated by jOOQ.") then (no)
        if (**Class contains references to jOOQ DSL**\n----\norg.jooq.impl.DSL, org.jooq.DSLContext) then (yes)
            repeat :**Read next statement constructed using jOOQ DSL**\n----\nChain of methods starting with DSL/DSLContext;
                if (**Statement is a SELECT statement**\n----\nStarts with any variation of select or selectFrom) then (yes)
                    if (**SELECT statement has a GROUP BY clause**\n----\ngroupBy) then (yes)
                        repeat :**Read next selected column from SELECT clause**\n----\nNext argument in select function;
                            if (**Selected column is listed in GROUP BY clause**) then (no)
                                if (**Selected column is an aggregate function**\n----\nMethod in org.jooq.impl.DSL with return\ntype org.jooq.AggregateFunction) then (no)
                                    :**Detect antipattern** (line span: SELECT clause);
                                endif
                            endif
                        repeat while (**SELECT clause has another argument?**) is (yes) not (no)
                    endif
                endif
            repeat while (**Class has another statement constructed using jOOQ DSL?**) is (yes) not (no)
        endif
    endif
repeat while (**Class has another statement constructed using jOOQ DSL?**) is (yes) not (no)

stop
@enduml
