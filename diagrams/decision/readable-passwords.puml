@startuml readable-passwords
skinparam shadowing false
skinparam ConditionEndStyle hline
skinparam defaultTextAlignment center
start

repeat :**Read source class from project**;
if (**Class is generated by the jOOQ code generator**\n----\nClass is preceded by comment "This class is generated by jOOQ.") then (no)
    if (**Class contains references to jOOQ DSL**\n----\nImport statements or explicit references to org.jooq.impl.DSL, org.jooq.DSLContext) then (yes)
        repeat :**Read next statement constructed using jOOQ DSL**\n----\nChain of methods starting with DSL/DSLContext;
            if (**Statement is a INSERT/UPDATE/MERGE statement**\n----\ninsertInto, update, merge) then (yes)
                repeat :**Read next modified column**\n----\nNext "set" method in the chain;
                    if (**Column name indicates a password**\n----\npassword, pswd) then (yes)
                        if (**Assigned value is hashed**\n----\nDetermined by inspecting the call tree, looking for hashing) then (no)
                            :**Detect antipattern** (line span: assignment of password to column);
                        endif
                    endif
                repeat while (**Statement modifies another column?**) is (yes) not (no)
            endif
        repeat while (**Class has another statement constructed using jOOQ DSL?**) is (yes) not (no)
    endif
    if (**Class contains references to jOOQ generated DAOs**\n----\nImport statements or explicit references to classes in a package ending with .tables.daos) then (yes)
        repeat :**Read next call to a jOOQ generated repository method**\n----\nCall to a method from a class in a package ending with .tables.daos;
            if (**Call is to an INSERT/UPDATE/MERGE method**\n----\ninsert, update, merge) then (yes)
                repeat :**Read next field definition of the record class passed into the method**\n----\nFind next getter method in the record class;
                    if (**Field name indicates a password**\n----\npassword, pswd) then (yes)
                        if (**Field contains a hashed password at the call site**\n----\nDetermined by inspecting the call tree, looking for hashing) then (no)
                            :**Detect antipattern** (line span: assignment of password to record);
                        endif
                    endif
                repeat while (**Record class contains another field?**)
            endif
        repeat while (Class has another jOOQ statement or DAO call?) is (yes) not (no)
    endif
endif
repeat while (**Project contains another source class?**) is (yes) not (no)

stop
@enduml
