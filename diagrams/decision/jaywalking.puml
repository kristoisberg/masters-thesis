@startuml Jaywalking
skinparam shadowing false
skinparam ConditionEndStyle hline
skinparam defaultTextAlignment center
start

repeat :**Read source class from project**;
    if (**Class is generated by the jOOQ code generator**\n----\nClass is preceded by comment "This class is generated by jOOQ.") then (yes)
        if (**Class represents a database table**\n----\nClass implements org.jooq.Table) then (yes)
            repeat :**Read next column definition in class**\n----\nNext class field of type TableField;
                    if (**Column is of textual type**\n----\nDetermined by the second argument of createField\n----\nTEXT, VARCHAR, VARCHAR2, CLOB) then (yes)
                        if (**Column's name implies that the column stores multiple values**\n----\nName is plural, determined by the first argument of createField\n----\napplicable_entity_kinds, involvement_kind_ids, previous_passwords, recipients) then (yes)
                            if (**Column values are joined/split in application**\n----\nDetermined by inspecting business logic for\njoining/splitting logic related to the column) then (yes)
                                :**Detect antipattern** (line span: column definition);
                            endif
                        endif
                    endif
            repeat while (**Class has another column definition?**) is (yes) not (no)
        endif
    endif
repeat while (**Project contains another source class?**) is (yes) not (no)

stop
@enduml
